{
  "name": "markaz-ijro-android",
  "version": "1.0.0",
  "private": true,
  "description": "Markaz Ijro — Android wrapper around the production web app.",
  "scripts": {
    "sync": "cap sync android",
    "open": "cap open android",
    "build:debug": "cd android && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk ../markaz-ijro-debug.apk",
    "build:release": "cd android && ./gradlew assembleRelease",
    "build:bundle": "cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.1",
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/core": "^7.0.1",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/network": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.1",
    "typescript": "^6.0.3"
  }
}
